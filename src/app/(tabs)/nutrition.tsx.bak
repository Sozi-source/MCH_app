// ├втАЭтВм├втАЭтВм├втАЭтВм Swap Modal ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм

interface SwapModalProps {
  visible: boolean;
  slot: MealSlot | null;
  onClose: () => void;
  onSelect: (slot: MealSlot, newPrimary: EnrichedFood) => void;
  poolFoods: EnrichedFood[];
}

const SwapModal: React.FC<SwapModalProps> = ({
  visible, slot, onClose, onSelect, poolFoods,
}) => {
  const t = useT();
  const [selIdx, setSelIdx] = useState(0);
  const insets = useSafeAreaInsets();

  const alternatives = slot
    ? poolFoods
        .filter(f =>
          f.who_group === slot.primaryFood.who_group &&
          f.food_id   !== slot.primaryFood.food_id &&
          !['unga', 'flour', 'meal', 'raw'].some(w =>
            (f.food_name ?? '').toLowerCase().includes(w),
          ),
        )
        .filter((f, i, arr) =>
          arr.findIndex(x =>
            (x.local_name ?? x.food_name) === (f.local_name ?? f.food_name),
          ) === i,
        )
        .slice(0, 8)
    : [];

  return (
    <Modal visible={visible} transparent animationType="slide" onRequestClose={onClose}>
      <Pressable style={sm.overlay} onPress={onClose}>
        <Pressable
          style={[sm.sheet, { paddingBottom: insets.bottom + 16 }]}
          onPress={e => e.stopPropagation()}
        >
          <View style={sm.handle} />
          <Text style={sm.title}>
            {slot ? `${t(SLOT_KEY[slot.type])}` : 'Swap food'}
          </Text>
          <Text style={sm.sub}>
            Age & condition-safe alternatives from your food database
          </Text>

          {alternatives.length === 0 ? (
            <View style={sm.empty}>
              <Ionicons name="leaf-outline" size={28} color={COLORS.textMuted} />
              <Text style={sm.emptyText}>
                No alternatives found in this food group for the current age and conditions.
              </Text>
            </View>
          ) : (
            <ScrollView style={{ maxHeight: 340 }} showsVerticalScrollIndicator={false}>
              <View style={sm.grid}>
                {alternatives.map((food, i) => (
                  <TouchableOpacity
                    key={food.food_id}
                    style={[sm.card, selIdx === i && sm.cardSel]}
                    onPress={() => setSelIdx(i)}
                    activeOpacity={0.75}
                  >
                    <Text style={sm.emoji}>{pickEmoji(food.food_name, food.who_group, food.food_id)}</Text>
                    <Text style={sm.name} numberOfLines={2}>
                      {food.local_name ?? food.food_name}
                    </Text>
                    <View style={sm.nutRow}>
                      {food.iron_mg    ? <Text style={sm.nut}>├░┼╕┬й┬╕ {t('nutrient_iron')}</Text>    : null}
                      {food.vit_a_mcg  ? <Text style={sm.nut}>├░┼╕┼Т┼╕ {t('nutrient_vitamin_a')}</Text> : null}
                      {food.protein_g  ? <Text style={sm.nut}>├░┼╕тАЩ┬к {t('nutrient_protein')}</Text>  : null}
                      {food.vit_c_mg   ? <Text style={sm.nut}>├░┼╕┬Н┼а {t('nutrient_vitamin_c')}</Text> : null}
                      {food.energy_kcal ? <Text style={sm.nut}>{Math.round(food.energy_kcal)}kcal</Text> : null}
                    </View>
                  </TouchableOpacity>
                ))}
              </View>
            </ScrollView>
          )}

          <View style={sm.footer}>
            <TouchableOpacity style={sm.cancelBtn} onPress={onClose}>
              <Text style={sm.cancelText}>Cancel</Text>
            </TouchableOpacity>
            {alternatives.length > 0 && (
              <TouchableOpacity
                style={sm.confirmBtn}
                onPress={() => {
                  if (slot && alternatives[selIdx]) onSelect(slot, alternatives[selIdx]);
                  onClose();
                }}
              >
                <Ionicons name="checkmark-circle-outline" size={16} color={COLORS.white} />
                <Text style={sm.confirmText}>Use this food</Text>
              </TouchableOpacity>
            )}
          </View>
        </Pressable>
      </Pressable>
    </Modal>
  );
};

const sm = StyleSheet.create({
  overlay:    { flex: 1, backgroundColor: 'rgba(0,0,0,0.45)', justifyContent: 'flex-end' },
  sheet:      { backgroundColor: COLORS.white, borderTopLeftRadius: 24, borderTopRightRadius: 24, paddingHorizontal: 20, paddingTop: 12 },
  handle:     { width: 36, height: 4, backgroundColor: COLORS.border, borderRadius: 2, alignSelf: 'center', marginBottom: 16 },
  title:      { fontFamily: FONTS.bold, fontSize: 18, color: COLORS.textPrimary, marginBottom: 4 },
  sub:        { fontFamily: FONTS.regular, fontSize: 12, color: COLORS.textMuted, marginBottom: 16, lineHeight: 17 },
  grid:       { flexDirection: 'row', flexWrap: 'wrap', gap: 8 },
  card:       { width: (W - 56) / 2, backgroundColor: COLORS.surface, borderRadius: RADIUS.lg, borderWidth: 1, borderColor: COLORS.border, padding: 12, alignItems: 'center', gap: 4 },
  cardSel:    { borderColor: COLORS.primary, backgroundColor: COLORS.primaryLight },
  emoji:      { fontSize: 26, marginBottom: 4 },
  name:       { fontFamily: FONTS.semibold, fontSize: 12, color: COLORS.textPrimary, textAlign: 'center' },
  nutRow:     { flexDirection: 'row', flexWrap: 'wrap', gap: 3, justifyContent: 'center' },
  nut:        { fontFamily: FONTS.regular, fontSize: 10, color: COLORS.textMuted },
  empty:      { alignItems: 'center', paddingVertical: 32, gap: 8 },
  emptyText:  { fontFamily: FONTS.regular, fontSize: 13, color: COLORS.textMuted, textAlign: 'center', lineHeight: 18 },
  footer:     { flexDirection: 'row', gap: 10, paddingTop: 16, borderTopWidth: 1, borderTopColor: COLORS.border, marginTop: 16 },
  cancelBtn:  { flex: 1, paddingVertical: 13, borderRadius: RADIUS.lg, borderWidth: 1, borderColor: COLORS.border, alignItems: 'center' },
  cancelText: { fontFamily: FONTS.semibold, fontSize: 14, color: COLORS.textSecondary },
  confirmBtn: { flex: 2, flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 6, paddingVertical: 13, borderRadius: RADIUS.lg, backgroundColor: COLORS.primary },
  confirmText:{ fontFamily: FONTS.semibold, fontSize: 14, color: COLORS.white },
});

