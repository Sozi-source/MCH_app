  if (n.includes('egg'))                                        return 'ЁЯеЪ';
  if (n.includes('beef') || n.includes('goat') || n.includes('lamb') || n.includes('pork') || n.includes('meat')) return 'ЁЯей';
  if (n.includes('sausage'))                                    return 'ЁЯМн';
  if (n.includes('ugali'))                                      return 'ЁЯМ╜';
  if (n.includes('uji') || n.includes('porridge') || n.includes('wimbi') || n.includes('millet')) return 'ЁЯег';
  if (n.includes('chapati'))                                    return 'ЁЯлУ';
  if (n.includes('mandazi') || n.includes('mahamri'))           return 'ЁЯНй';
  if (n.includes('bread'))                                      return 'ЁЯНЮ';
  if (n.includes('rice'))                                       return 'ЁЯНЪ';
  if (n.includes('pasta') || n.includes('noodle') || n.includes('spaghetti') || n.includes('tambi')) return 'ЁЯНЭ';
  if (n.includes('maize') || n.includes('corn') || n.includes('posho')) return 'ЁЯМ╜';
  if (n.includes('sorghum') || n.includes('mtama'))             return 'ЁЯМ╛';
  if (n.includes('oat'))                                        return 'ЁЯег';
  if (n.includes('cassava') || n.includes('muhogo'))            return 'ЁЯНа';
  if (n.includes('sweet potato') || n.includes('viazi vitamu')) return 'ЁЯНа';
  if (n.includes('potato') || n.includes('viazi'))              return 'ЁЯеФ';
  if (n.includes('yam') || n.includes('arrowroot') || n.includes('nduma') || n.includes('cocoyam')) return 'ЁЯНа';
  if (n.includes('plantain') || n.includes('matoke'))           return 'ЁЯНМ';
  if (n.includes('githeri') || n.includes('mukimo'))            return 'ЁЯН▓';
  if (n.includes('injera'))                                     return 'ЁЯлУ';
  if (n.includes('quinoa') || n.includes('teff') || n.includes('barley') || n.includes('wheat')) return 'ЁЯМ╛';
  if (n.includes('popcorn'))                                    return 'ЁЯН┐';
  if (n.includes('cereal') || n.includes('weetabix'))           return 'ЁЯег';
  if (n.includes('bean') || n.includes('lentil') || n.includes('maharagwe') || n.includes('dengu')) return 'ЁЯлШ';
  if (n.includes('pea') || n.includes('mbaazi') || n.includes('chickpea') || n.includes('cowpea'))  return 'ЁЯлШ';
  if (n.includes('groundnut') || n.includes('peanut') || n.includes('karanga')) return 'ЁЯеЬ';
  if (n.includes('cashew') || n.includes('macadamia') || n.includes('nut'))     return 'ЁЯеЬ';
  if (n.includes('sesame') || n.includes('simsim') || n.includes('sunflower seed') || n.includes('pumpkin seed')) return 'ЁЯМ░';
  if (n.includes('soybean') || n.includes('soya'))              return 'ЁЯлШ';
  if (n.includes('milk') || n.includes('maziwa') || n.includes('mala') || n.includes('mtindi') || n.includes('yoghurt') || n.includes('mursik')) return 'ЁЯеЫ';
  if (n.includes('cheese') || n.includes('chizi'))              return 'ЁЯзА';
  if (n.includes('butter') || n.includes('siagi') || n.includes('ghee') || n.includes('margarine')) return 'ЁЯзИ';
  if (n.includes('oil') || n.includes('mafuta'))                return 'ЁЯлЩ';
  if (n.includes('avocado') || n.includes('parachichi'))        return 'ЁЯеС';
  if (n.includes('tomato') || n.includes('nyanya'))             return 'ЁЯНЕ';
  if (n.includes('carrot') || n.includes('karoti'))             return 'ЁЯеХ';
  if (n.includes('pumpkin') || n.includes('butternut') || n.includes('squash') || n.includes('boga')) return 'ЁЯОГ';
  if (n.includes('spinach') || n.includes('mchicha') || n.includes('kale') || n.includes('sukuma')) return 'ЁЯем';
  if (n.includes('amaranth') || n.includes('terere'))           return 'ЁЯем';
  if (n.includes('moringa'))                                    return 'ЁЯМ┐';
  if (n.includes('cabbage') || n.includes('kabichi'))           return 'ЁЯем';
  if (n.includes('broccoli'))                                   return 'ЁЯеж';
  if (n.includes('cauliflower'))                                return 'ЁЯеж';
  if (n.includes('mushroom') || n.includes('uyoga'))            return 'ЁЯНД';
  if (n.includes('eggplant') || n.includes('brinjal') || n.includes('biringanya')) return 'ЁЯНЖ';
  if (n.includes('okra') || n.includes('bamia'))                return 'ЁЯМ┐';
  if (n.includes('cucumber') || n.includes('tango') || n.includes('zucchini')) return 'ЁЯеТ';
  if (n.includes('pepper') || n.includes('pilipili') || n.includes('hoho')) return 'ЁЯлС';
  if (n.includes('onion') || n.includes('kitunguu') || n.includes('garlic') || n.includes('leek')) return 'ЁЯзЕ';
  if (n.includes('beetroot') || n.includes('biiti'))            return 'ЁЯлЪ';
  if (n.includes('lettuce') || n.includes('saladi'))            return 'ЁЯеЧ';
  if (n.includes('mango') || n.includes('embe'))                return 'ЁЯен';
  if (n.includes('banana') || n.includes('ndizi'))              return 'ЁЯНМ';
  if (n.includes('orange') || n.includes('chungwa'))            return 'ЁЯНК';
  if (n.includes('lemon') || n.includes('lime') || n.includes('ndimu')) return 'ЁЯНЛ';
  if (n.includes('passion'))                                    return 'ЁЯНЛ';
  if (n.includes('papaya') || n.includes('pawpaw') || n.includes('papai')) return 'ЁЯНИ';
  if (n.includes('pineapple') || n.includes('nanasi'))          return 'ЁЯНН';
  if (n.includes('coconut') || n.includes('nazi') || n.includes('dafu')) return 'ЁЯее';
  if (n.includes('watermelon') || n.includes('tikiti'))         return 'ЁЯНЙ';
  if (n.includes('guava') || n.includes('mapera'))              return 'ЁЯНИ';
  if (n.includes('jackfruit') || n.includes('fenesi'))          return 'ЁЯНИ';
  if (n.includes('strawberry'))                                 return 'ЁЯНУ';
  if (n.includes('grape') || n.includes('zabibu') || n.includes('gooseberry') || n.includes('mulberry')) return 'ЁЯНЗ';
  if (n.includes('apple') || n.includes('tofaa'))               return 'ЁЯНО';
  if (n.includes('peach') || n.includes('apricot') || n.includes('plum') || n.includes('loquat')) return 'ЁЯНС';
  if (n.includes('soursop') || n.includes('mstafeli'))          return 'ЁЯНИ';
  if (n.includes('tamarind') || n.includes('ukwaju'))           return 'ЁЯЯд';
  if (n.includes('honey') || n.includes('asali'))               return 'ЁЯНп';
  if (n.includes('sugar') || n.includes('sukari'))              return 'ЁЯНм';
  if (n.includes('molasses') || n.includes('jaggery'))          return 'ЁЯЯд';
  if (n.includes('sugarcane') || n.includes('miwa'))            return 'ЁЯМ┐';
  if (n.includes('water') || n.includes('maji'))                return 'ЁЯТз';
  if (n.includes('tea') || n.includes('chai'))                  return 'ЁЯН╡';
  if (n.includes('coffee') || n.includes('kahawa'))             return 'тШХ';
  if (n.includes('juice') || n.includes('juisi'))               return 'ЁЯед';
  if (n.includes('soda'))                                       return 'ЁЯед';
  if (n.includes('salt') || n.includes('chumvi'))               return 'ЁЯзВ';
  if (n.includes('royco') || n.includes('seasoning'))           return 'ЁЯзВ';
  if (n.includes('chilli') || n.includes('pilipili manga'))     return 'ЁЯМ╢я╕П';
  if (n.includes('spice') || n.includes('curry') || n.includes('masala') || n.includes('herb') || n.includes('coriander') || n.includes('dania') || n.includes('rosemary') || n.includes('cinnamon') || n.includes('clove') || n.includes('cardamom') || n.includes('turmeric') || n.includes('ginger')) return 'ЁЯМ┐';
  if (n.includes('biscuit') || n.includes('cookie') || n.includes('biskuti')) return 'ЁЯНк';
  if (n.includes('crisp') || n.includes('chip') || n.includes('vibanzi'))     return 'ЁЯеФ';
  if (n.includes('infant') || n.includes('formula') || n.includes('cerelac')) return 'ЁЯН╝';
  if (n.includes('rutf') || n.includes('plumpy'))               return 'ЁЯПе';

  const g = whoGroup.toLowerCase();
  if (g.includes('fish') || g.includes('marine') || g.includes('freshwater')) return 'ЁЯРЯ';
  if (g.includes('shellfish') || g.includes('seafood'))          return 'ЁЯжР';
  if (g.includes('poultry'))                                     return 'ЁЯНЧ';
  if (g.includes('egg'))                                         return 'ЁЯеЪ';
  if (g.includes('meat') || g.includes('offal') || g.includes('game')) return 'ЁЯей';
  if (g.includes('legume') || g.includes('bean') || g.includes('pea') || g.includes('lentil') || g.includes('soy')) return 'ЁЯлШ';
  if (g.includes('nut') || g.includes('seed'))                   return 'ЁЯеЬ';
  if (g.includes('dairy') || g.includes('milk') || g.includes('cheese')) return 'ЁЯеЫ';
  if (g.includes('grain') || g.includes('cereal') || g.includes('millet') || g.includes('sorghum') || g.includes('rice') || g.includes('wheat') || g.includes('maize')) return 'ЁЯМ╛';
  if (g.includes('root') || g.includes('starchy') || g.includes('tuber')) return 'ЁЯНа';
  if (g.includes('dark leafy') || g.includes('leafy') || g.includes('greens')) return 'ЁЯем';
  if (g.includes('vegetable') || g.includes('brassica'))         return 'ЁЯеж';
  if (g.includes('fruit'))                                       return 'ЁЯНО';
  if (g.includes('oil') || g.includes('fat'))                   return 'ЁЯлЩ';
  if (g.includes('spice') || g.includes('herb') || g.includes('condiment') || g.includes('seasoning')) return 'ЁЯМ┐';
  if (g.includes('sugar') || g.includes('sweetener'))           return 'ЁЯНм';
  if (g.includes('beverage') || g.includes('water') || g.includes('juice')) return 'ЁЯТз';

  return 'ЁЯН╜я╕П';
}

const MEAL_TIMES: Record<MealSlotType, string> = {
  'Breakfast':         '7:00 AM',
  'Morning snack':     '10:00 AM',
  'Lunch':             '12:30 PM',
  'Afternoon snack':   '3:00 PM',
  'Dinner':            '6:00 PM',
};

// ├втАЭтВм├втАЭтВм├втАЭтВм Referral Card ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм

interface ReferralCardProps {
  severity: string;
  reason: string;
  childName: string;
  waz: number | null;
  haz: number | null;
  whz: number | null;
}

const ReferralCard: React.FC<ReferralCardProps> = ({
  severity, reason, childName, waz, haz, whz,
}) => {
  const t = useT();
  const isCritical = severity === 'critical';
  const bg     = isCritical ? COLORS.missedLight : COLORS.dueLight;
  const border = isCritical ? COLORS.missed      : COLORS.due;

  return (
    <View style={[rc.card, { backgroundColor: bg, borderColor: border + '55' }]}>
      <View style={rc.header}>
        <Ionicons name={isCritical ? 'alert-circle' : 'warning'} size={20} color={border} />
        <Text style={[rc.title, { color: border }]}>
          {isCritical ? '├░┼╕┼б┬и  ' : '├в┼б┬а├п┬╕┬П  '}{t('referral_title')}
        </Text>
      </View>
      <Text style={[rc.reason, { color: border }]}>{reason}</Text>
      <View style={rc.scores}>
        {waz != null && (
          <View style={[rc.chip, { borderColor: border + '44' }]}>
            <Text style={[rc.chipLabel, { color: border }]}>WAZ</Text>
            <Text style={[rc.chipVal, { color: border }]}>{waz.toFixed(1)}</Text>
          </View>
        )}
        {haz != null && (
          <View style={[rc.chip, { borderColor: border + '44' }]}>
            <Text style={[rc.chipLabel, { color: border }]}>HAZ</Text>
            <Text style={[rc.chipVal, { color: border }]}>{haz.toFixed(1)}</Text>
          </View>
        )}
        {whz != null && (
          <View style={[rc.chip, { borderColor: border + '44' }]}>
            <Text style={[rc.chipLabel, { color: border }]}>WHZ</Text>
            <Text style={[rc.chipVal, { color: border }]}>{whz.toFixed(1)}</Text>
          </View>
        )}
      </View>
      {isCritical && (
        <View style={rc.rutfBox}>
          <Ionicons name="medkit-outline" size={14} color={border} />
          <Text style={[rc.rutfText, { color: border }]}>
            {childName} may be eligible for RUTF (Ready-to-Use Therapeutic Food).
            Visit your nearest MCH clinic immediately for SAM assessment.
          </Text>
        </View>
      )}
      <TouchableOpacity
        style={[rc.btn, { backgroundColor: border }]}
        onPress={() => Linking.openURL('tel:0800723253')}
        activeOpacity={0.8}
      >
        <Ionicons name="call-outline" size={14} color={COLORS.white} />
        <Text style={rc.btnText}>
          {isCritical ? 'Call Kenya Health Hotline' : 'Book MCH Appointment'}
        </Text>
      </TouchableOpacity>
      <Text style={[rc.source, { color: border + 'AA' }]}>
        WHO/UNICEF SAM Protocol 2023 ├В┬╖ Kenya MoH IMAM Guidelines
      </Text>
    </View>
  );
};

const rc = StyleSheet.create({
  card:      { borderRadius: RADIUS.lg, borderWidth: 1.5, padding: 16, marginBottom: 14, gap: 10 },
  header:    { flexDirection: 'row', alignItems: 'center', gap: 8 },
  title:     { fontFamily: FONTS.bold, fontSize: 14, flex: 1 },
  reason:    { fontFamily: FONTS.regular, fontSize: 13, lineHeight: 19 },
  scores:    { flexDirection: 'row', gap: 8, flexWrap: 'wrap' },
  chip:      { borderWidth: 1, borderRadius: 10, paddingHorizontal: 10, paddingVertical: 5, alignItems: 'center', gap: 1 },
  chipLabel: { fontFamily: FONTS.regular, fontSize: 9, letterSpacing: 0.5 },
  chipVal:   { fontFamily: FONTS.bold, fontSize: 16 },
  rutfBox:   { flexDirection: 'row', alignItems: 'flex-start', gap: 8, backgroundColor: 'rgba(255,255,255,0.6)', borderRadius: RADIUS.md, padding: 10 },
  rutfText:  { fontFamily: FONTS.regular, fontSize: 12, flex: 1, lineHeight: 17 },
  btn:       { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 6, paddingVertical: 11, borderRadius: RADIUS.lg },
  btnText:   { fontFamily: FONTS.semibold, fontSize: 13, color: COLORS.white },
  source:    { fontFamily: FONTS.regular, fontSize: 10, textAlign: 'center' },
});

// ├втАЭтВм├втАЭтВм├втАЭтВм Meal Card ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
interface MealCardProps {
  slot: MealSlot;
  index: number;
  onSwap: (slot: MealSlot) => void;
}

const MealCard = React.memo(({ slot, index, onSwap }: MealCardProps) => {
  const t = useT();
  const fade  = useRef(new Animated.Value(0)).current;
  const slide = useRef(new Animated.Value(16)).current;
  const [expanded, setExpanded] = useState(false);

  useEffect(() => {
    Animated.parallel([
      Animated.timing(fade,  { toValue: 1, duration: 300, delay: index * 60, useNativeDriver: true }),
      Animated.timing(slide, { toValue: 0, duration: 300, delay: index * 60, useNativeDriver: true }),
    ]).start();
  }, []);

  const emoji       = pickEmoji(slot.primaryFood.food_name, slot.primaryFood.who_group, slot.primaryFood.food_id);
  const accentColor = slot.isSnack ? COLORS.primary : COLORS.given;
  const badgeBg     = slot.isSnack ? COLORS.upcomingLight : COLORS.givenLight;
  const badgeColor  = slot.isSnack ? COLORS.upcoming      : COLORS.given;

  return (
    <Animated.View style={{ opacity: fade, transform: [{ translateY: slide }] }}>
      <View style={mc.card}>
        <View style={[mc.accent, { backgroundColor: accentColor }]} />
        <View style={mc.body}>

          {/* Collapsed header тАФ tap to expand */}
          <TouchableOpacity style={mc.header} onPress={() => setExpanded(e => !e)} activeOpacity={0.75}>
            <View style={{ flex: 1, flexDirection: 'row', alignItems: 'flex-start', gap: 10, paddingRight: 8 }}>
              <Text style={mc.emoji}>{emoji}</Text>
              <View style={{ flex: 1 }}>
                <Text style={mc.mealType}>{t(SLOT_KEY[slot.type])}</Text>
                <Text style={mc.mealName} numberOfLines={2}>{slot.mealName}</Text>
              </View>
            </View>
            <View style={[mc.badge, { backgroundColor: badgeBg }]}>
              <Ionicons
                name={slot.isSnack ? 'cafe-outline' : 'restaurant-outline'}
                size={11}
                color={badgeColor}
              />
              <Text style={[mc.badgeText, { color: badgeColor }]}>
                {slot.isSnack ? t('snack_label') : t('meal_label')}
              </Text>
            </View>
          </View>

          {/* Time + max serving */}
          <View style={mc.metaRow}>
            <Ionicons name="time-outline" size={12} color={COLORS.textMuted} />
            <Text style={mc.metaText}>{MEAL_TIMES[slot.type]}</Text>
            {slot.primaryFood.max_serving_g != null && (
              <>
                <View style={mc.dot} />
                <Ionicons name="scale-outline" size={12} color={COLORS.due} />
                <Text style={[mc.metaText, { color: COLORS.due }]}>
                  Max {slot.primaryFood.max_serving_g}g
                </Text>
              </>
            )}
          </View>

          {/* Nutrient tags ├втВмтАЭ translated */}
          <View style={mc.tags}>
            {slot.nutrients.map(tag => {
              const ts = tagStyle(tag);
              const label = t(NUTRIENT_KEY[tag] ?? tag);
              return (
                <View key={tag} style={[mc.tag, { backgroundColor: ts.bg }]}>
                  <Text style={[mc.tagText, { color: ts.color }]}>{label}</Text>
                </View>
              );
            })}
          </View>

          {/* Foods breakdown */}
          <View style={mc.foodsRow}>
            {[slot.primaryFood, slot.secondFood, slot.thirdFood]
              .filter(Boolean)
              .map(food => (
                <View key={food!.food_id} style={mc.foodChip}>
                  <Text style={mc.foodEmoji}>{pickEmoji(food!.food_name, food!.who_group, food!.food_id)}</Text>
                  <Text style={mc.foodName} numberOfLines={1}>
                    {food!.local_name ?? food!.food_name}
                  </Text>
                  {food!.energy_kcal != null && (
                    <Text style={mc.foodKcal}>{Math.round(food!.energy_kcal)} kcal</Text>
                  )}
                </View>
              ))}
          </View>

          {/* Synergy note */}
          {!!slot.synergyNote && (
            <View style={mc.synergyBox}>
              <Ionicons name="flash-outline" size={11} color={COLORS.primary} />
              <Text style={mc.synergyText}>
                <Text style={{ fontFamily: FONTS.semibold }}>{t('synergy_note_label')}: </Text>
                {slot.synergyNote}
              </Text>
            </View>
          )}

          <View style={mc.divider} />
          <View style={{ flexDirection: 'row', gap: 8 }}>
            <TouchableOpacity style={mc.swapBtn} onPress={() => onSwap(slot)} activeOpacity={0.7}>
              <Ionicons name="swap-horizontal-outline" size={14} color={COLORS.primary} />
              <Text style={mc.swapText}>Swap food</Text>
            </TouchableOpacity>
          </View>

        </View>
      </View>
    </Animated.View>
  );
});
MealCard.displayName = 'MealCard';

const mc = StyleSheet.create({
  card:           { flexDirection: 'row', backgroundColor: COLORS.white, borderRadius: RADIUS.lg, borderWidth: 1, borderColor: COLORS.border, marginBottom: 10, overflow: 'hidden' },
  accent:         { width: 4 },
  body:           { flex: 1, paddingHorizontal: 14, paddingTop: 13, paddingBottom: 11 },
  header:         { flexDirection: 'row', alignItems: 'flex-start', gap: 10 },
