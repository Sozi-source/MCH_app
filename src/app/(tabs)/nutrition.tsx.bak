function getAgeMonths(dob: string): number {
  const b = new Date(dob);
  const n = new Date();
  let m = (n.getFullYear() - b.getFullYear()) * 12 + (n.getMonth() - b.getMonth());
  if (n.getDate() < b.getDate()) m--;
  return Math.max(0, m);
}

function energyTargetLabel(age: number): string {
  if (age < 9)  return '200 kcal/day';
  if (age < 12) return '300 kcal/day';
  if (age < 24) return '550 kcal/day';
  return '~1,000 kcal/day';
}

function wazStatusLabel(waz: number | null, t: (k: string) => string): string {
  if (waz == null) return 'No growth data';
  if (waz < -3) return t('condition_sam');
  if (waz < -2) return t('condition_mam');
  if (waz < -1) return 'Mildly underweight';
  if (waz <= 1) return 'Normal weight-for-age';
  return 'Above average weight';
}

function wazBadge(waz: number | null) {
  if (waz == null)
    return { label: 'No data', bg: COLORS.surface, color: COLORS.textMuted, icon: 'help-circle-outline' as const };
  if (waz < -3)
    return { label: 'SAM ├втВмтАЭ refer', bg: COLORS.missedLight, color: COLORS.missed, icon: 'alert-circle' as const };
  if (waz < -2)
    return { label: 'MAM', bg: COLORS.dueLight, color: COLORS.due, icon: 'warning' as const };
  if (waz < -1)
    return { label: 'Mild risk', bg: COLORS.upcomingLight, color: COLORS.upcoming, icon: 'information-circle' as const };
  return { label: 'Normal', bg: COLORS.givenLight, color: COLORS.given, icon: 'checkmark-circle' as const };
}

function tagStyle(tag: string): { bg: string; color: string } {
  const lower = tag.toLowerCase();
  if (lower.includes('iron') || lower.includes('zinc') || lower.includes('vitamin c'))
    return { bg: COLORS.givenLight, color: COLORS.given };
  if (lower.includes('vitamin a') || lower.includes('energy') || lower.includes('omega'))
    return { bg: COLORS.upcomingLight, color: COLORS.upcoming };
  if (lower.includes('protein') || lower.includes('b12'))
    return { bg: COLORS.dueLight, color: COLORS.due };
  if (lower.includes('calcium') || lower.includes('fibre'))
    return { bg: COLORS.primaryLight, color: COLORS.primary };
  return { bg: COLORS.surface, color: COLORS.textSecondary };
}

